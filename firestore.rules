
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ATURAN PENGEMBANGAN: Izinkan semua akses baca dan tulis untuk mempermudah prototyping.
    // Memastikan pengguna anonim dapat melakukan verifikasi dan pencarian data di landing page.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
