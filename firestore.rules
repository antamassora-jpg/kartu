
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isScanner() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_scanner/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /roles_scanner/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin() || isScanner();
      allow write: if isAdmin();
    }

    match /public_student_verifications/{cardCode} {
      allow get: if true;
      allow list: if false;
    }

    match /school_settings/{settingId} {
      allow get: if true;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /templates/{templateId} {
      allow read: if isAdmin() || isScanner();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isAdmin() || isScanner();
      allow write: if isAdmin();
    }

    match /exam_cards/{examCardId} {
      allow read: if isAdmin() || isScanner();
      allow write: if isAdmin();
    }

    match /attendance_sessions/{sessionId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /attendance_logs/{logId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.scannedByUserId == request.auth.uid);
      allow list: if isAdmin() || isScanner();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
