
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ATURAN PENGEMBANGAN: Izinkan semua akses baca dan tulis untuk mempermudah prototyping
    // PERINGATAN: Jangan gunakan aturan ini di produksi.
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Stempel waktu pembaruan: 2024-05-20 18:30 (Akses Terbuka Penuh)
  }
}
